FROM --platform=$BUILDPLATFORM golang:1.26-alpine AS builder
ARG TARGETOS TARGETARCH
WORKDIR /src
COPY go.mod go.sum ./
RUN go mod download
COPY . .
RUN CGO_ENABLED=0 GOOS=$TARGETOS GOARCH=$TARGETARCH \
    go build -ldflags="-s -w" -o /bbroker-warden ./cmd/bbroker-warden

FROM gcr.io/distroless/static-debian12:nonroot
COPY --from=builder /bbroker-warden /bbroker-warden
ENTRYPOINT ["/bbroker-warden"]
